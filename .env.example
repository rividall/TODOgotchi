# Docker Compose project name (used for container naming)
COMPOSE_PROJECT_NAME=todogotchi

# PostgreSQL
POSTGRES_USER=todogotchi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=todogotchi

# Backend
DATABASE_URL=postgresql+asyncpg://todogotchi:changeme@db:5432/todogotchi
SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3004,https://porings.buenalynch.com

# Ports (host-side)
DB_PORT=5434
BACKEND_PORT=8004
FRONTEND_PORT=3004

# Frontend (build-time)
VITE_API_URL=/api/v1
